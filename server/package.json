{
  "name": "chronicle",
  "version": "1.0.0",
  "description": "Local-first task management server",
  "bin": {
    "chronicle": "dist/cli.js",
    "chronicle-setup": "dist/setup.js",
    "chronicle-server": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "mcp": "node ../skills/mcp-bridge.mjs",
    "postinstall": "node -e \"try{var fs=require('fs');if(fs.existsSync('dist/setup.js')){require('child_process').execSync('node dist/setup.js',{stdio:'inherit'})}}catch(e){}\""
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.4.0",
    "nodejieba": "^3.5.8",
    "pino": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3"
  }
}
