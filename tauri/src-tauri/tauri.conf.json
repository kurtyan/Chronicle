{
  "productName": "Chronicle",
  "version": "1.2.0",
  "identifier": "com.chronicle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:18090",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "/Users/yanke/**",
            "/tmp/**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    },
    "windows": [
      {
        "title": "Chronicle",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "devtools": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
